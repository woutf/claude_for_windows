{
  "name": "geminui",
  "version": "1.0.0",
  "description": "GeminUI - AI Desktop Assistant powered by Gemini CLI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "dist": "electron-builder --win --publish never"
  },
  "author": "GeminUI",
  "license": "MIT",
  "dependencies": {
    "dompurify": "^3.2.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "playwright": "^1.58.2"
  },
  "build": {
    "appId": "com.geminui.app",
    "productName": "GeminUI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "icon": "build/icon.png",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
